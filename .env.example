# =========================================================================
# ACTIVITY ATTENDANCE SYSTEM - DEPLOYMENT CONFIGURATION (ตัวแปรตั้งค่าระบบ)
# =========================================================================

# 1. Host Domain & Public Port (สำหรับเปิดใช้งานภายนอก)
# Domain name or IP address (e.g. localhost, attendance.mycompany.com)
DOMAIN=localhost

# Public Web Port (Port ที่ใช้งานจากภายนอกเข้า reverse proxy Nginx)
PORT=80

# 2. Back-End Server Internal Configuration (รันภายใน container)
# Internal port for the backend Node.js container
BACKEND_PORT=5000

# 3. Front-End Configuration (ทิ้งไว้เป็นค่าว่างสำหรับ Relative Path Mode)
# Leave empty so the application automatically uses relative pathing and window.location.origin
VITE_API_BASE_URL=
VITE_APP_URL=

# 4. Google Sheets Credentials
# Filename of the Google Sheets Service Account JSON key (must be in the root directory)
GOOGLE_CREDENTIALS_FILE=acoustic-arch-477716-p3-fcde8dc29abd.json
